// Prisma schema — FootManager
// Source de vérité fonctionnelle : docs/schema/index.md, fondations.md, joueurs.md, scouting.md
// Toute modification de ce fichier doit être reportée dans le fichier docs/schema/ concerné.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────
// Fondations — Auth, Clubs, Membres, Rôles (docs/schema/fondations.md)
// ─────────────────────────────────────────────────────────────────────────

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  passwordHash  String
  emailVerified Boolean  @default(false)
  locale        String   @default("fr")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  members       Member[]
  refreshTokens RefreshToken[]
  userRoles     UserRole[]
}

model RefreshToken {
  id        Int       @id @default(autoincrement())
  userId    Int
  user      User      @relation(fields: [userId], references: [id])
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum SportType {
  FOOTBALL
  BASKETBALL
  RUGBY
  HANDBALL
  VOLLEYBALL
}

model Club {
  id             Int       @id @default(autoincrement())
  name           String
  sport          SportType @default(FOOTBALL)
  logoUrl        String?
  primaryColor   String?
  secondaryColor String?
  country        String
  city           String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  teams                Team[]
  members              Member[]
  roles                Role[]
  memberRoles          MemberRole[]
  evaluationCategories EvaluationCategory[]
  evaluationCriteria   EvaluationCriterion[]
  evaluationConfigs    ClubEvaluationConfig[]
  playingStyleTags     PlayingStyleTag[]
  scoutingCriteria     PlayerScoutingCriterion[]
  seasons              Season[]
  externalTeams        ExternalTeam[]
}

model Team {
  id        Int      @id @default(autoincrement())
  clubId    Int
  club      Club     @relation(fields: [clubId], references: [id])
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberRoles                MemberRole[]
  playerTeams                PlayerTeam[]
  teamStaffs                 TeamStaff[]
  playerEvaluations          PlayerEvaluation[]
  events                     Event[]
  championships              Championship[]
  // Équipe engagée comme participante d'un championnat (le sien ou celui
  // d'une autre équipe du club) — distinct de `championships` ci-dessus
  // (les championnats que CETTE équipe organise).
  championshipParticipations ChampionshipParticipant[]

  @@index([clubId])
}

model Member {
  id        Int       @id @default(autoincrement())
  userId    Int?
  user      User?     @relation(fields: [userId], references: [id])
  clubId    Int
  club      Club      @relation(fields: [clubId], references: [id])
  firstName String
  lastName  String
  phone     String?
  avatarUrl String?
  gender    Gender?
  birthDate DateTime? @db.Date
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  memberRoles         MemberRole[]
  playerProfile       PlayerProfile?
  teamStaffs          TeamStaff[]
  conductedInterviews PlayerInterview[]  @relation("PlayerInterviewStaff")
  authoredNotes       PlayerNote[]
  assignedObjectives  PlayerObjective[]
  evaluationsGiven    PlayerEvaluation[]
  reportedAbsences    PlayerAbsence[]
  parentLinks         ParentChild[]      @relation("ParentChildAsParent")
  childLinks          ParentChild[]      @relation("ParentChildAsChild")

  @@unique([userId, clubId])
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  isSystem    Boolean
  clubId      Int?
  club        Club?    @relation(fields: [clubId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberRoles     MemberRole[]
  rolePermissions RolePermission[]
  userRoles       UserRole[]
}

model MemberRole {
  id        Int       @id @default(autoincrement())
  memberId  Int
  member    Member    @relation(fields: [memberId], references: [id])
  roleId    Int
  role      Role      @relation(fields: [roleId], references: [id])
  // `clubId = null` : mécanisme legacy, plus produit par aucun code depuis
  // l'introduction de UserRole ci-dessous et plus honoré par
  // PermissionsService.matchesContext (une telle ligne serait refusée, pas
  // auto-matchée) — voir docs/modules/auth-roles.md §Rôles plateforme. Les
  // rôles plateforme (SuperAdmin/Proprietaire) passent désormais par
  // UserRole, indépendant de tout Member/Club.
  clubId    Int?
  club      Club?     @relation(fields: [clubId], references: [id])
  teamId    Int?
  team      Team?     @relation(fields: [teamId], references: [id])
  startDate DateTime? @db.Date
  endDate   DateTime? @db.Date
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([memberId])
  @@index([clubId, teamId])
}

/**
 * Rôle plateforme — attribution d'un Role directement à un User, sans Member
 * ni Club (docs/modules/auth-roles.md §Rôles plateforme). Réservé en
 * pratique aux rôles système globaux (SuperAdmin, Proprietaire), granté via
 * le script backend/scripts/bootstrap-platform-role.ts. Pas de contrainte
 * unique sur (userId, roleId) : même historisation que MemberRole (une
 * révocation via endDate peut être suivie d'un nouveau grant, comme une
 * nouvelle ligne).
 */
model UserRole {
  id        Int       @id @default(autoincrement())
  userId    Int
  user      User      @relation(fields: [userId], references: [id])
  roleId    Int
  role      Role      @relation(fields: [roleId], references: [id])
  startDate DateTime? @db.Date
  endDate   DateTime? @db.Date
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
}

/**
 * Lien Parent ↔ Joueur (docs/decisions-ouvertes-et-rgpd.md #5, tranché —
 * voir docs/modules/auth-roles.md §Rôle Parent). Donne accès au scope
 * PermissionScope.PARENT sur les ressources de l'enfant. Créé/supprimé
 * uniquement par le staff (Coach/AdminClub/SuperAdmin) — jamais par le
 * Parent lui-même, donnée sensible sur un mineur, pas une auto-déclaration.
 * Pas de startDate/endDate (contrairement à MemberRole/UserRole) : un lien
 * erroné se corrige par suppression, pas par historisation.
 */
model ParentChild {
  id             Int      @id @default(autoincrement())
  parentMemberId Int
  parentMember   Member   @relation("ParentChildAsParent", fields: [parentMemberId], references: [id])
  childMemberId  Int
  childMember    Member   @relation("ParentChildAsChild", fields: [childMemberId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([parentMemberId, childMemberId])
  @@index([parentMemberId])
  @@index([childMemberId])
}

enum PermissionAction {
  READ
  CREATE
  UPDATE
  DELETE
}

enum PermissionScope {
  OWN
  // Accès à un enfant lié via ParentChild — voir ce modèle ci-dessus et
  // docs/modules/auth-roles.md §Rôle Parent. Chaque service qui l'utilise
  // vérifie d'abord "est-ce moi ?" (comme OWN) avant d'exiger le lien, pour
  // rester correct si un même membre cumule aussi un rôle Player sur le même
  // contexte club/équipe (voir le même paragraphe de doc).
  PARENT
  TEAM
  CLUB
  ALL
}

model Permission {
  id          Int              @id @default(autoincrement())
  resource    String
  action      PermissionAction
  scope       PermissionScope
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  rolePermissions RolePermission[]

  @@unique([resource, action, scope])
}

model RolePermission {
  roleId       Int
  role         Role       @relation(fields: [roleId], references: [id])
  permissionId Int
  permission   Permission @relation(fields: [permissionId], references: [id])
  createdAt    DateTime   @default(now())

  @@id([roleId, permissionId])
}

// ─────────────────────────────────────────────────────────────────────────
// Joueurs (partiel) — docs/schema/joueurs.md
// PlayerProfile/PlayerTeam/TeamStaff (Phase 2, module Effectif) + tables
// d'évaluation (seed système Phase 1). Décision du 2026-07-06 : Mesures,
// Entretien, Notes, Objectifs et Évaluation sont avancés dans cette phase
// (étape A7, une entité à la fois — voir docs/roadmap.md) plutôt que
// reportés en Phase 6. Seuls Dashboard (Phase 6) et Absence (Partie B /
// Phases 4-5) restent hors de cette phase ; Blessure reste Phase 8 (RGPD).
// ─────────────────────────────────────────────────────────────────────────

// Postes réels sur le terrain (football). La ligne (gardien/défense/milieu/
// attaque) n'est pas stockée : elle est dérivée en code applicatif à partir
// du poste précis (voir docs/schema/index.md) pour éviter une donnée
// dénormalisée à synchroniser.
enum Position {
  GK // Goalkeeper

  CB // Centre-Back
  RB // Right-Back
  LB // Left-Back
  RWB // Right Wing-Back
  LWB // Left Wing-Back

  CDM // Central Defensive Midfielder
  CM // Central Midfielder
  RM // Right Midfielder
  LM // Left Midfielder
  CAM // Central Attacking Midfielder

  RW // Right Winger
  LW // Left Winger
  CF // Centre-Forward
  ST // Striker
}

enum TeamStaffRole {
  PRINCIPAL
  CO_ENTRAINEUR
  ADJOINT
}

enum Foot {
  LEFT
  RIGHT
  BOTH
}

model PlayerProfile {
  id            Int      @id @default(autoincrement())
  memberId      Int      @unique
  member        Member   @relation(fields: [memberId], references: [id])
  // Pas d'unicité SQL globale : une licence est numérotée par fédération
  // nationale, pas mondialement, et FootManager n'a pas à arbitrer une
  // correspondance entre deux clubs différents. Vérifiée au niveau
  // applicatif, scopée au club (voir docs/schema/joueurs.md et
  // PlayersService.assertLicenseNumberAvailable).
  licenseNumber String?
  nationality   String?
  preferredFoot Foot?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  playerTeams        PlayerTeam[]
  playerMeasurements PlayerMeasurement[]
  playerInterviews   PlayerInterview[]
  playerNotes        PlayerNote[]
  playerObjectives   PlayerObjective[]
  playerEvaluations  PlayerEvaluation[]
  playerAbsences     PlayerAbsence[]
  matchAttendances   MatchAttendance[]
  matchLineups       MatchLineup[]
}

enum MeasurementType {
  HEIGHT
  WEIGHT
}

// Une ligne par mesure, jamais de mise à jour en place (docs/schema/joueurs.md)
// — historique complet pour la courbe d'évolution. Pas de route UPDATE :
// corriger une saisie erronée passe par DELETE + nouvelle entrée.
model PlayerMeasurement {
  id        Int             @id @default(autoincrement())
  playerId  Int
  player    PlayerProfile   @relation(fields: [playerId], references: [id])
  type      MeasurementType
  value     Decimal         @db.Decimal(5, 1)
  date      DateTime        @db.Date
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([playerId])
}

// Entretien individuel joueur-staff (docs/schema/joueurs.md). Permet de
// planifier un entretien à l'avance (date/subject/summary seuls requis) puis
// de le compléter après coup : `staffFeedback`, `staffAssessment` et
// `playerFeedback` sont tous les trois optionnels (décision du 2026-07-06,
// étape A7.2). `staffId` est assigné automatiquement au membre à l'origine de
// la création, jamais choisi dans un sélecteur.
//
// Visibilité par champ pour le rôle Player (scope OWN, voir
// PlayerInterviewsService.findAllByPlayer) : un Player ne voit que les
// entretiens passés (jamais ceux à venir) et jamais `staffAssessment` — c'est
// le ressenti/évaluation interne de l'encadrant, jamais communiqué au joueur.
// `staffFeedback` (conclusions retenues avec le joueur) et `playerFeedback`
// (ce que le joueur a exprimé, résumé par le staff) restent visibles par le
// joueur concerné, à la différence des notes `PRIVE` de `PlayerNote`. Même
// tension RGPD Article 15 que les notes privées (docs/decisions-ouvertes-et-rgpd.md).
model PlayerInterview {
  id              Int           @id @default(autoincrement())
  playerId        Int
  player          PlayerProfile @relation(fields: [playerId], references: [id])
  staffId         Int?
  staff           Member?       @relation("PlayerInterviewStaff", fields: [staffId], references: [id])
  date            DateTime      @db.Date
  subject         String
  summary         String        @db.Text
  staffFeedback   String?       @db.Text
  staffAssessment String?       @db.Text
  playerFeedback  String?       @db.Text
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([playerId])
}

// PRIVE = staff seulement. SEMI_PRIVE = joueur + staff. PUBLIC = parents +
// joueur + staff (docs/decisions-ouvertes-et-rgpd.md). Le rôle Parent n'est
// pas encore câblé sur le module Effectif (pas de table de liaison
// Parent↔Joueur, voir la décision ouverte correspondante) : seule la
// distinction PRIVE vs SEMI_PRIVE/PUBLIC est appliquée pour l'instant côté
// service (PlayerNotesService.findAllByPlayer).
enum NoteVisibility {
  PRIVE
  SEMI_PRIVE
  PUBLIC
}

// Notes du staff sur un joueur (docs/schema/joueurs.md). `authorId` est
// assigné automatiquement au membre à l'origine de la création, jamais
// choisi dans un sélecteur (même pattern que PlayerInterview.staffId).
// `trainingSessionId` (lien optionnel vers une séance) est différé à la
// Phase 5 — TrainingSession n'existe pas encore (module Entraînement non
// implémenté).
//
// Tension RGPD Article 15 : une note PRIVE n'est jamais transmise à un
// appelant en scope OWN (Player) — voir docs/decisions-ouvertes-et-rgpd.md.
model PlayerNote {
  id         Int            @id @default(autoincrement())
  playerId   Int
  player     PlayerProfile  @relation(fields: [playerId], references: [id])
  // Nullable (docs/decisions-ouvertes-et-rgpd.md) : un membre du STAFF peut
  // demander la suppression complète (anonymisation) de son compte plutôt
  // que son archivage — authorId passe alors à null sur ses notes existantes
  // plutôt que de bloquer ou de les supprimer.
  authorId   Int?
  author     Member?        @relation(fields: [authorId], references: [id])
  visibility NoteVisibility
  title      String?
  content    String         @db.Text
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([playerId])
}

enum ObjectiveTheme {
  TECHNIQUE
  PHYSIQUE
  MENTAL
  TACTIQUE
}

enum ObjectiveHorizon {
  SHORT_TERM
  MID_TERM
  LONG_TERM
}

enum ObjectiveStatus {
  PLANNED
  IN_PROGRESS
  ACHIEVED
  FAILED
}

// Objectif de développement d'un joueur (docs/schema/joueurs.md). Pas de lien
// à une saison fixe : suivi multi-saisons natif, reste `IN_PROGRESS` d'une
// saison à l'autre tant qu'il n'est pas `ACHIEVED` ou `FAILED`. `assignedById`
// est assigné automatiquement au membre à l'origine de la création (même
// pattern que `PlayerInterview.staffId`/`PlayerNote.authorId`), jamais choisi
// dans un sélecteur.
//
// Visibilité par défaut `SEMI_PRIVE` (décision documentée dans
// effectif-joueurs.md — défaut `PRIVE` était un bug identifié et corrigé) :
// contrairement à `PlayerNote`, un joueur voit ses propres objectifs par
// défaut. Même modèle de visibilité et même filtrage PRIVE pour le scope OWN
// que `PlayerNotesService.findAllByPlayer`.
model PlayerObjective {
  id            Int              @id @default(autoincrement())
  playerId      Int
  player        PlayerProfile    @relation(fields: [playerId], references: [id])
  theme         ObjectiveTheme
  description   String           @db.Text
  horizon       ObjectiveHorizon
  status        ObjectiveStatus  @default(PLANNED)
  visibility    NoteVisibility   @default(SEMI_PRIVE)
  startDate     DateTime?        @db.Date
  dueDate       DateTime?        @db.Date
  completedDate DateTime?        @db.Date
  assignedById  Int?
  assignedBy    Member?          @relation(fields: [assignedById], references: [id])
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([playerId])
}

enum AbsenceReason {
  INJURY
  ILLNESS
  VACATION
  OTHER
}

// Indépendante de l'équipe : s'applique à toutes les activités du joueur sur
// la période (docs/schema/joueurs.md §PlayerAbsence). Pas de rapprochement
// automatique avec les convocations (MatchAttendance/TrainingAttendance
// n'existent pas encore) — différé aux Phases 4/5. `reason` en liste fermée
// (plutôt que texte libre) pour permettre des statistiques par motif
// (ex. nombre d'entraînements manqués pour blessure) ; `description` reste
// un texte libre optionnel pour préciser le contexte.
model PlayerAbsence {
  id           Int           @id @default(autoincrement())
  playerId     Int
  player       PlayerProfile @relation(fields: [playerId], references: [id])
  reason       AbsenceReason
  description  String?       @db.Text
  startDate    DateTime      @db.Date
  endDate      DateTime      @db.Date
  isExcused    Boolean?
  reportedById Int?
  reportedBy   Member?       @relation(fields: [reportedById], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([playerId, startDate])
}

model PlayerTeam {
  id                 Int           @id @default(autoincrement())
  playerId           Int
  player             PlayerProfile @relation(fields: [playerId], references: [id])
  teamId             Int
  team               Team          @relation(fields: [teamId], references: [id])
  jerseyNumber       Int?
  mainPosition       Position?
  // Un joueur peut couvrir plusieurs postes secondaires (décision du
  // 2026-07-06) — tableau plutôt qu'une table de jointure séparée : borné
  // aux 15 valeurs de l'enum, jamais interrogé indépendamment de son
  // PlayerTeam (pas besoin de filtrer/jointurer dessus).
  secondaryPositions Position[]    @default([])
  joinDate           DateTime?     @db.Date
  leaveDate          DateTime?     @db.Date
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  // Pas de contrainte SQL sur (teamId, jerseyNumber) : l'historisation par
  // joinDate/leaveDate autorise la réattribution d'un numéro d'une saison à
  // l'autre. Unicité du numéro parmi les affectations ACTIVES (leaveDate
  // NULL) vérifiée au niveau applicatif (module players, étape A3).
  @@index([playerId])
  @@index([teamId])
}

model TeamStaff {
  id        Int           @id @default(autoincrement())
  teamId    Int
  team      Team          @relation(fields: [teamId], references: [id])
  memberId  Int
  member    Member        @relation(fields: [memberId], references: [id])
  staffRole TeamStaffRole
  startDate DateTime?     @db.Date
  endDate   DateTime?     @db.Date
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([teamId, memberId])
}

enum EventType {
  TRAINING
  MATCH
  OTHER
}

// Événement générique du calendrier (docs/modules/calendrier-evenements.md,
// docs/schema/evenements.md) — entité parente de tout ce qui s'affiche dans
// le calendrier. TrainingSession et Match l'étendront en relation 1-1
// (Phases 4/5, pas encore implémentées). `recurringRuleId` différé : la
// future entité RecurringRule n'existe pas encore (même logique que
// trainingSessionId sur PlayerNote — champ ajouté une fois le modèle cible
// disponible, pas anticipé ici).
model Event {
  id               Int       @id @default(autoincrement())
  teamId           Int
  team             Team      @relation(fields: [teamId], references: [id])
  type             EventType
  title            String
  startAt          DateTime
  endAt            DateTime?
  location         String?
  description      String?   @db.Text
  isRecurring      Boolean   @default(false)
  // Identifiant partagé par toutes les occurrences créées en une seule fois
  // par EventsService.createBulk (docs/roadmap.md — événements récurrents) —
  // permet de retrouver "cet événement et les suivants" pour une édition/
  // suppression en masse (scope=future), sans entité RecurringRule dédiée.
  // null pour un événement non récurrent.
  recurringGroupId String?   @db.Uuid
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  match Match? // extension 1-1 pour type = MATCH (Phase 4)

  @@index([teamId, startAt])
  @@index([recurringGroupId])
}

// ─────────────────────────────────────────────────────────────────────────
// Match (Phase 4) — docs/modules/matchs.md, docs/schema/evenements.md
// Extension 1-1 d'un Event de type MATCH. Décisions actées le 2026-07-16
// avant le premier incrément (voir docs/roadmap.md Phase 4) :
// - MatchType à 4 valeurs (CHAMPIONNAT/COUPE/AMICAL/TOURNOI).
// - Un match CHAMPIONNAT n'est jamais créé directement ici : il naît d'un
//   ChampionshipMatch (module Championnat) qui crée l'Event+Match en
//   transaction (MatchesService, A3) — championshipMatchId non-null,
//   opponentExternalTeamId/cupRound restent null (adversaire dérivé du
//   ChampionshipParticipant).
// - Un match COUPE/AMICAL/TOURNOI se crée directement depuis le Calendrier :
//   opponentExternalTeamId non-null (liste ExternalTeam existante ou
//   création à la volée), championshipMatchId reste null.
// - cupRound n'est renseigné que si matchType = COUPE — pas de bracket, pas
//   d'entité de compétition dédiée (décision MVP, voir docs/roadmap.md).
// Contraintes ci-dessus vérifiées en applicatif (MatchesService), pas par
// une CHECK constraint SQL — même approche que ChampionshipParticipant.
// ─────────────────────────────────────────────────────────────────────────

enum MatchType {
  CHAMPIONNAT
  COUPE
  AMICAL
  TOURNOI
}

// Phase de coupe à élimination directe — comptée en nombre d'équipes encore
// en lice (convention anglaise standard), PAS en nombre de matchs restants
// (convention française : "8e de finale" = 16 équipes = ROUND_OF_16, pas
// ROUND_OF_8 — piège à ne pas reproduire côté i18n/UI).
enum CupRound {
  ROUND_OF_128 // 128 équipes — "64e de finale"
  ROUND_OF_64 // 64 équipes — "32e de finale"
  ROUND_OF_32 // 32 équipes — "16e de finale"
  ROUND_OF_16 // 16 équipes — "8e de finale" (huitièmes)
  QUARTER_FINAL // 8 équipes — "quart de finale"
  SEMI_FINAL // 4 équipes — "demi-finale"
  FINAL // 2 équipes — "finale"
}

enum HomeOrAway {
  HOME
  AWAY
}

enum LiveMatchStatus {
  SCHEDULED
  LIVE
  HALFTIME
  FINISHED
  CANCELLED
  POSTPONED
}

model Match {
  id      Int   @id @default(autoincrement())
  eventId Int   @unique
  event   Event @relation(fields: [eventId], references: [id])

  // Non-null seulement pour matchType = CHAMPIONNAT — seule FK réelle de la
  // relation 1-1 avec ChampionshipMatch (celui-ci n'a pas de colonne matchId
  // physique, voir ChampionshipMatch ci-dessous : évite une double source de
  // vérité pour la même relation, docs/schema/index.md §Zéro duplicata).
  championshipMatchId Int?               @unique
  championshipMatch   ChampionshipMatch? @relation(fields: [championshipMatchId], references: [id])

  matchType MatchType

  // Non-null seulement pour matchType != CHAMPIONNAT (adversaire choisi
  // depuis la liste ExternalTeam du club, existante ou créée à la volée).
  opponentExternalTeamId Int?
  opponentExternalTeam   ExternalTeam? @relation(fields: [opponentExternalTeamId], references: [id])

  // Non-null seulement pour matchType = COUPE.
  cupRound CupRound?

  // Pour CHAMPIONNAT, dérivé à la création depuis la position de notre
  // équipe dans le ChampionshipMatch (home/awayParticipant). Pour les 3
  // autres types, choisi directement par le Coach à la création.
  homeOrAway HomeOrAway

  status LiveMatchStatus @default(SCHEDULED)

  // Écrase le défaut hérité du Championship (matchs CHAMPIONNAT) ou le
  // standard 2x45 (autres types) si renseigné.
  numberOfPeriods       Int?
  periodDurationMinutes Int?

  // Null si championshipMatchId est non-null — score de référence alors sur
  // ChampionshipMatch (docs/schema/championnats.md §ChampionshipMatch).
  scoreHome Int?
  scoreAway Int?

  globalRating  Decimal? @db.Decimal(4, 1) // sur 10, voir docs/schema/index.md
  globalComment String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attendances MatchAttendance[]
  lineups     MatchLineup[]

  @@index([opponentExternalTeamId])
}

// Réponse à une convocation — enum global (docs/schema/index.md), premier
// usage réel ici (Phase 4) ; réutilisé tel quel par TrainingAttendance en
// Phase 5.
enum ConvocationStatus {
  PENDING
  ACCEPTED
  DECLINED
}

// Présence réelle le jour J — enum global (docs/schema/index.md), même
// remarque que ConvocationStatus.
enum AttendanceStatus {
  PRESENT
  ABSENT_EXCUSE
  ABSENT_NON_EXCUSE
}

// Convocations et présences à un match (Phase 4, Partie B — docs/schema/
// evenements.md §MatchAttendance). `convocationStatus` posé par le Coach à
// la création (toujours PENDING), modifié ensuite par le joueur/parent
// concerné (ACCEPTED/DECLINED) — jamais par le Coach. `attendanceStatus`
// renseigné le jour J (présences effectives), par le Coach uniquement.
model MatchAttendance {
  id       Int           @id @default(autoincrement())
  matchId  Int
  match    Match         @relation(fields: [matchId], references: [id])
  playerId Int
  player   PlayerProfile @relation(fields: [playerId], references: [id])

  convocationStatus ConvocationStatus @default(PENDING)
  attendanceStatus  AttendanceStatus?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([matchId, playerId])
  @@index([matchId])
}

enum LineupStatus {
  TITULAIRE
  REMPLACANT
  NON_CONVOQUE
}

// Composition d'un match (Phase 4, Partie B — docs/schema/evenements.md
// §MatchLineup). `position`/`shirtNumber` sont propres à CE match (peuvent
// différer de PlayerTeam.mainPosition/jerseyNumber, ex. dépannage à un
// poste inhabituel) — jamais lus depuis PlayerTeam.
model MatchLineup {
  id       Int           @id @default(autoincrement())
  matchId  Int
  match    Match         @relation(fields: [matchId], references: [id])
  playerId Int
  player   PlayerProfile @relation(fields: [playerId], references: [id])

  lineupStatus LineupStatus
  position     Position?
  // Identifiant du point sur le terrain SVG (ex. "cb-left", voir
  // frontend/src/lib/positions.ts POSITION_PITCH_SPOTS) — distinct de
  // `position` : deux joueurs peuvent partager le même `position` (2 CB) mais
  // occupent chacun un point différent du terrain. Champ purement visuel,
  // pas de table de correspondance côté backend (source de vérité = le
  // frontend), donc une simple chaîne plutôt qu'un enum Prisma à resynchroniser.
  pitchSpotId String?
  shirtNumber Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([matchId, playerId])
  @@unique([matchId, pitchSpotId])
  @@index([matchId])
}

model EvaluationCategory {
  id                  Int        @id @default(autoincrement())
  name                String
  description         String?
  isSystem            Boolean
  sport               SportType?
  defaultDisplayOrder Int
  clubId              Int?
  club                Club?      @relation(fields: [clubId], references: [id])
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  criteria          EvaluationCriterion[]
  evaluationConfigs ClubEvaluationConfig[]

  @@index([clubId])
}

model ClubEvaluationConfig {
  id           Int                @id @default(autoincrement())
  clubId       Int
  club         Club               @relation(fields: [clubId], references: [id])
  categoryId   Int
  category     EvaluationCategory @relation(fields: [categoryId], references: [id])
  isEnabled    Boolean            @default(true)
  displayOrder Int?
  customName   String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@unique([clubId, categoryId])
  @@index([clubId])
}

model EvaluationCriterion {
  id          Int                @id @default(autoincrement())
  name        String
  categoryId  Int
  category    EvaluationCategory @relation(fields: [categoryId], references: [id])
  isSystem    Boolean
  clubId      Int?
  club        Club?              @relation(fields: [clubId], references: [id])
  description String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  evaluationScores PlayerEvaluationScore[]

  @@index([categoryId])
}

// Une évaluation = une session où le coach note TOUS les critères actifs du
// club en une fois (docs/schema/joueurs.md) — pas une ligne par critère : le
// radar affiche la session la plus récente (moyenne par catégorie), les
// sessions précédentes restent en base pour l'historique (un tableau, une
// ligne par date, une colonne par catégorie). `evaluatorId` est assigné
// automatiquement au membre à l'origine de la création (même pattern que
// PlayerInterview.staffId), donc nullable seulement pour permettre un futur
// import de données historiques sans auteur identifié. `trainingSessionId`/
// `matchId` (liens optionnels vers une séance/un match) sont différés aux
// Phases 5/4 — ces modèles n'existent pas encore. `comments` est global à la
// session, pas par critère.
model PlayerEvaluation {
  id          Int           @id @default(autoincrement())
  playerId    Int
  player      PlayerProfile @relation(fields: [playerId], references: [id])
  date        DateTime      @db.Date
  evaluatorId Int?
  evaluator   Member?       @relation(fields: [evaluatorId], references: [id])
  // Contexte d'équipe si le joueur évolue dans plusieurs équipes — jamais
  // utilisé pour la vérification de permission (assertPlayerInTeam se base
  // sur l'appartenance réelle du joueur à l'équipe transmise en query, pas
  // sur ce champ).
  teamId      Int?
  team        Team?         @relation(fields: [teamId], references: [id])
  comments    String?       @db.Text
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  scores PlayerEvaluationScore[]

  @@index([playerId, date])
}

// Note d'un critère donné au sein d'une session PlayerEvaluation. UPDATE
// autorisé (pas de contrainte append-only comme PlayerMeasurement) : un
// score mal saisi se corrige, il n'a pas besoin d'être historisé — l'édition
// remplace l'ensemble des scores de la session (voir PlayerEvaluationsService.update).
model PlayerEvaluationScore {
  id           Int                 @id @default(autoincrement())
  evaluationId Int
  evaluation   PlayerEvaluation    @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  criterionId  Int
  criterion    EvaluationCriterion @relation(fields: [criterionId], references: [id])
  score        Decimal             @db.Decimal(4, 1)

  @@unique([evaluationId, criterionId])
  @@index([evaluationId])
}

// ─────────────────────────────────────────────────────────────────────────
// Saisons & Championnats (Partie A — Season, Partie B — Championship en
// cours) — docs/schema/championnats.md, docs/modules/saisons-championnats.md.
// Championship/ChampionshipParticipant/ChampionshipMatch arrivent plus loin
// en Partie B (Phase 3, roadmap.md B4/B7/B10).
// ─────────────────────────────────────────────────────────────────────────

enum SeasonStatus {
  DRAFT // en préparation, la saison précédente reste ACTIVE
  ACTIVE // saison courante — une seule par Club à tout instant
  ARCHIVED // saison terminée, données consultables et modifiables
}

// Cadre temporel PARTAGÉ PAR TOUT LE CLUB (docs/modules/saisons-championnats.md
// — révision A14 : Season était initialement scopée équipe, déplacée au
// niveau club car toutes les équipes d'un club suivent le même calendrier de
// saisons). Une seule Season avec status = ACTIVE par Club à tout instant, et
// les plages de dates de deux Season d'un même club ne peuvent jamais se
// chevaucher — contraintes applicatives (SeasonsService), pas des contraintes
// SQL. Les saisons archivées restent modifiables sans verrou (comportement
// attendu, pas un bug — voir la doc module). Pas de logique de roster
// attachée : PlayerTeam n'a pas de FK directe vers Season (appartenance
// déduite de joinDate/leaveDate), les mouvements de joueurs entre équipes
// (départs, arrivées, promotions de catégorie) se gèrent au fil de l'eau via
// l'Effectif, pas via un wizard de transition de saison.
model Season {
  id        Int          @id @default(autoincrement())
  clubId    Int
  club      Club         @relation(fields: [clubId], references: [id])
  name      String
  startDate DateTime     @db.Date
  endDate   DateTime     @db.Date
  status    SeasonStatus @default(DRAFT)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  championships Championship[]

  @@index([clubId, status])
}

// Équipe adverse (docs/schema/championnats.md §ExternalTeam) — scopée au
// CLUB (pas au Championship ni à la Team) : créée une fois, réutilisable
// d'un championnat/d'une saison à l'autre, potentiellement affrontée par
// plusieurs équipes du même club. `ExternalPlayer` (joueur d'une équipe
// adverse) est hors scope Partie B — arrive en Phase 7 Scouting, malgré sa
// présence dans le même fichier de doc.
model ExternalTeam {
  id        Int      @id @default(autoincrement())
  clubId    Int
  club      Club     @relation(fields: [clubId], references: [id])
  name      String
  city      String?
  country   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participations  ChampionshipParticipant[]
  opponentMatches Match[] // matchs Coupe/Amical/Tournoi joués contre cette équipe (Phase 4)

  @@index([clubId])
}

// Championnat d'une équipe au sein d'une saison (docs/schema/championnats.md
// §Championship) — décision tranchée au démarrage de la Partie B (docs/
// roadmap.md, point reporté depuis la révision A14) : `Season` est club-wide
// depuis A14, donc `seasonId` seul ne suffit plus à identifier l'équipe.
// `Championship` porte son propre `teamId` en plus de `seasonId` (chaque
// équipe joue son propre championnat au sein de la même saison partagée) et
// aucune contrainte d'unicité `teamId`+`seasonId` : une équipe peut avoir
// plusieurs championnats sur une même saison (ex. U15 "Championnat
// d'Automne" ET "Championnat du Printemps", cas réel signalé par
// l'utilisateur). Créé par les Coachs eux-mêmes (permission TEAM CRUD, voir
// B0), à tout moment, découplé de la création de la saison — pas de wizard.
// `tiebreakerRules` reste un simple Json (tableau ordonné de `TiebreakerRule`,
// validé côté DTO applicatif) plutôt qu'un enum Postgres — cohérent avec la
// nature "ordre choisi par l'utilisateur" de la donnée.
model Championship {
  id                    Int      @id @default(autoincrement())
  seasonId              Int
  season                Season   @relation(fields: [seasonId], references: [id])
  teamId                Int
  team                  Team     @relation(fields: [teamId], references: [id])
  name                  String
  startDate             DateTime @db.Date
  endDate               DateTime @db.Date
  pointsForWin          Int      @default(3)
  pointsForDraw         Int      @default(1)
  pointsForLoss         Int      @default(0)
  tiebreakerRules       Json
  tiebreakerPreset      String?
  numberOfPeriods       Int      @default(2)
  periodDurationMinutes Int      @default(45)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  participants ChampionshipParticipant[]
  matches      ChampionshipMatch[]

  @@index([seasonId])
  @@index([teamId])
}

// Équipe participante à un championnat (docs/schema/championnats.md
// §ChampionshipParticipant) : soit une de nos équipes (`internalTeamId`),
// soit une équipe adverse (`externalTeamId`) — exactement l'une des deux,
// jamais les deux ni aucune. Pas de contrainte SQL native pour "exactement
// l'un des deux" avec Prisma (pas de CHECK constraint généré) : vérifiée en
// applicatif (ChampionshipParticipantsService, B8), même approche que le
// non-chevauchement des dates de Season.
model ChampionshipParticipant {
  id             Int           @id @default(autoincrement())
  championshipId Int
  championship   Championship  @relation(fields: [championshipId], references: [id])
  internalTeamId Int?
  internalTeam   Team?         @relation(fields: [internalTeamId], references: [id])
  externalTeamId Int?
  externalTeam   ExternalTeam? @relation(fields: [externalTeamId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  homeMatches ChampionshipMatch[] @relation("HomeMatches")
  awayMatches ChampionshipMatch[] @relation("AwayMatches")

  @@index([championshipId])
}

enum ChampionshipMatchStatus {
  SCHEDULED
  FINISHED
  CANCELLED
  POSTPONED
}

// Rencontre dans un championnat (docs/schema/championnats.md
// §ChampionshipMatch) — couvre toutes les rencontres, les nôtres et celles
// entre adversaires. Règle de score — source de vérité unique : un match
// AMICAL/COUPE/TOURNOI (championshipMatchId null sur Match, Phase 4) stocke
// son score sur Match.scoreHome/Away ; un match de CHAMPIONNAT le stocke ici
// (scoreHome/Away), Match.scoreHome/Away reste NULL.
//
// Pas de colonne `matchId` ici (contrairement à la Phase 3, où elle existait
// sans `@relation` en dérogation assumée, faute de modèle Match) : la seule
// FK réelle de cette relation 1-1 est désormais Match.championshipMatchId
// (@unique) — `match` ci-dessous est la relation Prisma inverse, sans
// colonne physique, pour éviter une double source de vérité
// (docs/schema/index.md §Zéro duplicata). Un ChampionshipMatch n'obtient un
// Match lié que si l'une de nos équipes y participe (MatchesService, A3) —
// une rencontre entre deux adversaires n'a jamais de Match/Event associé.
model ChampionshipMatch {
  id                    Int                     @id @default(autoincrement())
  championshipId        Int
  championship          Championship            @relation(fields: [championshipId], references: [id])
  homeParticipantId     Int
  homeParticipant       ChampionshipParticipant @relation("HomeMatches", fields: [homeParticipantId], references: [id])
  awayParticipantId     Int
  awayParticipant       ChampionshipParticipant @relation("AwayMatches", fields: [awayParticipantId], references: [id])
  scheduledAt           DateTime
  scoreHome             Int?
  scoreAway             Int?
  status                ChampionshipMatchStatus @default(SCHEDULED)
  match                 Match?
  round                 Int?
  numberOfPeriods       Int?
  periodDurationMinutes Int?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  @@index([championshipId])
}

// ─────────────────────────────────────────────────────────────────────────
// Scouting (partiel) — docs/schema/scouting.md
// Uniquement les tables de référence pour le seed système Phase 1.
// Le reste du module (TeamScoutingReport, PlayerScoutingReport, etc.) arrive en Phase 7.
// ─────────────────────────────────────────────────────────────────────────

model PlayingStyleTag {
  id        Int      @id @default(autoincrement())
  name      String
  isSystem  Boolean
  clubId    Int?
  club      Club?    @relation(fields: [clubId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clubId])
}

enum ScoutingDimension {
  PHYSIQUE
  TECHNIQUE
  TACTIQUE
  MENTAL
}

model PlayerScoutingCriterion {
  id          Int               @id @default(autoincrement())
  name        String
  dimension   ScoutingDimension
  isSystem    Boolean
  clubId      Int?
  club        Club?             @relation(fields: [clubId], references: [id])
  description String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([clubId])
}
