// Prisma schema — FootManager
// Source de vérité fonctionnelle : docs/schema/index.md, fondations.md, joueurs.md, scouting.md
// Toute modification de ce fichier doit être reportée dans le fichier docs/schema/ concerné.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────
// Fondations — Auth, Clubs, Membres, Rôles (docs/schema/fondations.md)
// ─────────────────────────────────────────────────────────────────────────

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  passwordHash  String
  emailVerified Boolean  @default(false)
  locale        String   @default("fr")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  members       Member[]
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        Int       @id @default(autoincrement())
  userId    Int
  user      User      @relation(fields: [userId], references: [id])
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum SportType {
  FOOTBALL
  BASKETBALL
  RUGBY
  HANDBALL
  VOLLEYBALL
}

model Club {
  id             Int       @id @default(autoincrement())
  name           String
  sport          SportType @default(FOOTBALL)
  logoUrl        String?
  primaryColor   String?
  secondaryColor String?
  country        String
  city           String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  teams                Team[]
  members              Member[]
  roles                Role[]
  memberRoles          MemberRole[]
  evaluationCategories EvaluationCategory[]
  evaluationCriteria   EvaluationCriterion[]
  evaluationConfigs    ClubEvaluationConfig[]
  playingStyleTags     PlayingStyleTag[]
  scoutingCriteria     PlayerScoutingCriterion[]
}

model Team {
  id        Int      @id @default(autoincrement())
  clubId    Int
  club      Club     @relation(fields: [clubId], references: [id])
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberRoles       MemberRole[]
  playerTeams       PlayerTeam[]
  teamStaffs        TeamStaff[]
  playerEvaluations PlayerEvaluation[]

  @@index([clubId])
}

model Member {
  id        Int      @id @default(autoincrement())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
  clubId    Int
  club      Club     @relation(fields: [clubId], references: [id])
  firstName String
  lastName  String
  phone     String?
  avatarUrl String?
  gender    Gender?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberRoles         MemberRole[]
  playerProfile       PlayerProfile?
  teamStaffs          TeamStaff[]
  conductedInterviews PlayerInterview[]  @relation("PlayerInterviewStaff")
  authoredNotes       PlayerNote[]
  assignedObjectives  PlayerObjective[]
  evaluationsGiven    PlayerEvaluation[]

  @@unique([userId, clubId])
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  isSystem    Boolean
  clubId      Int?
  club        Club?    @relation(fields: [clubId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberRoles     MemberRole[]
  rolePermissions RolePermission[]
}

model MemberRole {
  id        Int       @id @default(autoincrement())
  memberId  Int
  member    Member    @relation(fields: [memberId], references: [id])
  roleId    Int
  role      Role      @relation(fields: [roleId], references: [id])
  clubId    Int?
  club      Club?     @relation(fields: [clubId], references: [id])
  teamId    Int?
  team      Team?     @relation(fields: [teamId], references: [id])
  startDate DateTime? @db.Date
  endDate   DateTime? @db.Date
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([memberId])
  @@index([clubId, teamId])
}

enum PermissionAction {
  READ
  CREATE
  UPDATE
  DELETE
}

enum PermissionScope {
  OWN
  TEAM
  CLUB
  ALL
}

model Permission {
  id          Int              @id @default(autoincrement())
  resource    String
  action      PermissionAction
  scope       PermissionScope
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  rolePermissions RolePermission[]

  @@unique([resource, action, scope])
}

model RolePermission {
  roleId       Int
  role         Role       @relation(fields: [roleId], references: [id])
  permissionId Int
  permission   Permission @relation(fields: [permissionId], references: [id])
  createdAt    DateTime   @default(now())

  @@id([roleId, permissionId])
}

// ─────────────────────────────────────────────────────────────────────────
// Joueurs (partiel) — docs/schema/joueurs.md
// PlayerProfile/PlayerTeam/TeamStaff (Phase 2, module Effectif) + tables
// d'évaluation (seed système Phase 1). Décision du 2026-07-06 : Mesures,
// Entretien, Notes, Objectifs et Évaluation sont avancés dans cette phase
// (étape A7, une entité à la fois — voir docs/roadmap.md) plutôt que
// reportés en Phase 6. Seuls Dashboard (Phase 6) et Absence (Partie B /
// Phases 4-5) restent hors de cette phase ; Blessure reste Phase 8 (RGPD).
// ─────────────────────────────────────────────────────────────────────────

// Postes réels sur le terrain (football). La ligne (gardien/défense/milieu/
// attaque) n'est pas stockée : elle est dérivée en code applicatif à partir
// du poste précis (voir docs/schema/index.md) pour éviter une donnée
// dénormalisée à synchroniser.
enum Position {
  GK // Goalkeeper

  CB // Centre-Back
  RB // Right-Back
  LB // Left-Back
  RWB // Right Wing-Back
  LWB // Left Wing-Back

  CDM // Central Defensive Midfielder
  CM // Central Midfielder
  RM // Right Midfielder
  LM // Left Midfielder
  CAM // Central Attacking Midfielder

  RW // Right Winger
  LW // Left Winger
  CF // Centre-Forward
  ST // Striker
}

enum TeamStaffRole {
  PRINCIPAL
  CO_ENTRAINEUR
  ADJOINT
}

enum Foot {
  LEFT
  RIGHT
  BOTH
}

model PlayerProfile {
  id            Int       @id @default(autoincrement())
  memberId      Int       @unique
  member        Member    @relation(fields: [memberId], references: [id])
  licenseNumber String?   @unique
  nationality   String?
  birthDate     DateTime? @db.Date
  preferredFoot Foot?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  playerTeams        PlayerTeam[]
  playerMeasurements PlayerMeasurement[]
  playerInterviews   PlayerInterview[]
  playerNotes        PlayerNote[]
  playerObjectives   PlayerObjective[]
  playerEvaluations  PlayerEvaluation[]
}

enum MeasurementType {
  HEIGHT
  WEIGHT
}

// Une ligne par mesure, jamais de mise à jour en place (docs/schema/joueurs.md)
// — historique complet pour la courbe d'évolution. Pas de route UPDATE :
// corriger une saisie erronée passe par DELETE + nouvelle entrée.
model PlayerMeasurement {
  id        Int             @id @default(autoincrement())
  playerId  Int
  player    PlayerProfile   @relation(fields: [playerId], references: [id])
  type      MeasurementType
  value     Decimal         @db.Decimal(5, 1)
  date      DateTime        @db.Date
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([playerId])
}

// Entretien individuel joueur-staff (docs/schema/joueurs.md). Permet de
// planifier un entretien à l'avance (date/subject/summary seuls requis) puis
// de le compléter après coup : `staffFeedback`, `staffAssessment` et
// `playerFeedback` sont tous les trois optionnels (décision du 2026-07-06,
// étape A7.2). `staffId` est assigné automatiquement au membre à l'origine de
// la création, jamais choisi dans un sélecteur.
//
// Visibilité par champ pour le rôle Player (scope OWN, voir
// PlayerInterviewsService.findAllByPlayer) : un Player ne voit que les
// entretiens passés (jamais ceux à venir) et jamais `staffAssessment` — c'est
// le ressenti/évaluation interne de l'encadrant, jamais communiqué au joueur.
// `staffFeedback` (conclusions retenues avec le joueur) et `playerFeedback`
// (ce que le joueur a exprimé, résumé par le staff) restent visibles par le
// joueur concerné, à la différence des notes `PRIVE` de `PlayerNote`. Même
// tension RGPD Article 15 que les notes privées (docs/decisions-ouvertes-et-rgpd.md).
model PlayerInterview {
  id              Int           @id @default(autoincrement())
  playerId        Int
  player          PlayerProfile @relation(fields: [playerId], references: [id])
  staffId         Int?
  staff           Member?       @relation("PlayerInterviewStaff", fields: [staffId], references: [id])
  date            DateTime      @db.Date
  subject         String
  summary         String        @db.Text
  staffFeedback   String?       @db.Text
  staffAssessment String?       @db.Text
  playerFeedback  String?       @db.Text
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([playerId])
}

// PRIVE = staff seulement. SEMI_PRIVE = joueur + staff. PUBLIC = parents +
// joueur + staff (docs/decisions-ouvertes-et-rgpd.md). Le rôle Parent n'est
// pas encore câblé sur le module Effectif (pas de table de liaison
// Parent↔Joueur, voir la décision ouverte correspondante) : seule la
// distinction PRIVE vs SEMI_PRIVE/PUBLIC est appliquée pour l'instant côté
// service (PlayerNotesService.findAllByPlayer).
enum NoteVisibility {
  PRIVE
  SEMI_PRIVE
  PUBLIC
}

// Notes du staff sur un joueur (docs/schema/joueurs.md). `authorId` est
// assigné automatiquement au membre à l'origine de la création, jamais
// choisi dans un sélecteur (même pattern que PlayerInterview.staffId).
// `trainingSessionId` (lien optionnel vers une séance) est différé à la
// Phase 5 — TrainingSession n'existe pas encore (module Entraînement non
// implémenté).
//
// Tension RGPD Article 15 : une note PRIVE n'est jamais transmise à un
// appelant en scope OWN (Player) — voir docs/decisions-ouvertes-et-rgpd.md.
model PlayerNote {
  id         Int            @id @default(autoincrement())
  playerId   Int
  player     PlayerProfile  @relation(fields: [playerId], references: [id])
  authorId   Int
  author     Member         @relation(fields: [authorId], references: [id])
  visibility NoteVisibility
  title      String?
  content    String         @db.Text
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([playerId])
}

enum ObjectiveTheme {
  TECHNIQUE
  PHYSIQUE
  MENTAL
  TACTIQUE
}

enum ObjectiveHorizon {
  SHORT_TERM
  MID_TERM
  LONG_TERM
}

enum ObjectiveStatus {
  PLANNED
  IN_PROGRESS
  ACHIEVED
  FAILED
}

// Objectif de développement d'un joueur (docs/schema/joueurs.md). Pas de lien
// à une saison fixe : suivi multi-saisons natif, reste `IN_PROGRESS` d'une
// saison à l'autre tant qu'il n'est pas `ACHIEVED` ou `FAILED`. `assignedById`
// est assigné automatiquement au membre à l'origine de la création (même
// pattern que `PlayerInterview.staffId`/`PlayerNote.authorId`), jamais choisi
// dans un sélecteur.
//
// Visibilité par défaut `SEMI_PRIVE` (décision documentée dans
// effectif-joueurs.md — défaut `PRIVE` était un bug identifié et corrigé) :
// contrairement à `PlayerNote`, un joueur voit ses propres objectifs par
// défaut. Même modèle de visibilité et même filtrage PRIVE pour le scope OWN
// que `PlayerNotesService.findAllByPlayer`.
model PlayerObjective {
  id            Int              @id @default(autoincrement())
  playerId      Int
  player        PlayerProfile    @relation(fields: [playerId], references: [id])
  theme         ObjectiveTheme
  description   String           @db.Text
  horizon       ObjectiveHorizon
  status        ObjectiveStatus  @default(PLANNED)
  visibility    NoteVisibility   @default(SEMI_PRIVE)
  startDate     DateTime?        @db.Date
  dueDate       DateTime?        @db.Date
  completedDate DateTime?        @db.Date
  assignedById  Int?
  assignedBy    Member?          @relation(fields: [assignedById], references: [id])
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([playerId])
}

model PlayerTeam {
  id                 Int           @id @default(autoincrement())
  playerId           Int
  player             PlayerProfile @relation(fields: [playerId], references: [id])
  teamId             Int
  team               Team          @relation(fields: [teamId], references: [id])
  jerseyNumber       Int?
  mainPosition       Position?
  // Un joueur peut couvrir plusieurs postes secondaires (décision du
  // 2026-07-06) — tableau plutôt qu'une table de jointure séparée : borné
  // aux 15 valeurs de l'enum, jamais interrogé indépendamment de son
  // PlayerTeam (pas besoin de filtrer/jointurer dessus).
  secondaryPositions Position[]    @default([])
  joinDate           DateTime?     @db.Date
  leaveDate          DateTime?     @db.Date
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  // Pas de contrainte SQL sur (teamId, jerseyNumber) : l'historisation par
  // joinDate/leaveDate autorise la réattribution d'un numéro d'une saison à
  // l'autre. Unicité du numéro parmi les affectations ACTIVES (leaveDate
  // NULL) vérifiée au niveau applicatif (module players, étape A3).
  @@index([playerId])
  @@index([teamId])
}

model TeamStaff {
  id        Int           @id @default(autoincrement())
  teamId    Int
  team      Team          @relation(fields: [teamId], references: [id])
  memberId  Int
  member    Member        @relation(fields: [memberId], references: [id])
  staffRole TeamStaffRole
  startDate DateTime?     @db.Date
  endDate   DateTime?     @db.Date
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([teamId, memberId])
}

model EvaluationCategory {
  id                  Int        @id @default(autoincrement())
  name                String
  description         String?
  isSystem            Boolean
  sport               SportType?
  defaultDisplayOrder Int
  clubId              Int?
  club                Club?      @relation(fields: [clubId], references: [id])
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  criteria          EvaluationCriterion[]
  evaluationConfigs ClubEvaluationConfig[]

  @@index([clubId])
}

model ClubEvaluationConfig {
  id           Int                @id @default(autoincrement())
  clubId       Int
  club         Club               @relation(fields: [clubId], references: [id])
  categoryId   Int
  category     EvaluationCategory @relation(fields: [categoryId], references: [id])
  isEnabled    Boolean            @default(true)
  displayOrder Int?
  customName   String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@unique([clubId, categoryId])
  @@index([clubId])
}

model EvaluationCriterion {
  id          Int                @id @default(autoincrement())
  name        String
  categoryId  Int
  category    EvaluationCategory @relation(fields: [categoryId], references: [id])
  isSystem    Boolean
  clubId      Int?
  club        Club?              @relation(fields: [clubId], references: [id])
  description String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  evaluationScores PlayerEvaluationScore[]

  @@index([categoryId])
}

// Une évaluation = une session où le coach note TOUS les critères actifs du
// club en une fois (docs/schema/joueurs.md) — pas une ligne par critère : le
// radar affiche la session la plus récente (moyenne par catégorie), les
// sessions précédentes restent en base pour l'historique (un tableau, une
// ligne par date, une colonne par catégorie). `evaluatorId` est assigné
// automatiquement au membre à l'origine de la création (même pattern que
// PlayerInterview.staffId), donc nullable seulement pour permettre un futur
// import de données historiques sans auteur identifié. `trainingSessionId`/
// `matchId` (liens optionnels vers une séance/un match) sont différés aux
// Phases 5/4 — ces modèles n'existent pas encore. `comments` est global à la
// session, pas par critère.
model PlayerEvaluation {
  id          Int           @id @default(autoincrement())
  playerId    Int
  player      PlayerProfile @relation(fields: [playerId], references: [id])
  date        DateTime      @db.Date
  evaluatorId Int?
  evaluator   Member?       @relation(fields: [evaluatorId], references: [id])
  // Contexte d'équipe si le joueur évolue dans plusieurs équipes — jamais
  // utilisé pour la vérification de permission (assertPlayerInTeam se base
  // sur l'appartenance réelle du joueur à l'équipe transmise en query, pas
  // sur ce champ).
  teamId      Int?
  team        Team?         @relation(fields: [teamId], references: [id])
  comments    String?       @db.Text
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  scores PlayerEvaluationScore[]

  @@index([playerId, date])
}

// Note d'un critère donné au sein d'une session PlayerEvaluation. UPDATE
// autorisé (pas de contrainte append-only comme PlayerMeasurement) : un
// score mal saisi se corrige, il n'a pas besoin d'être historisé — l'édition
// remplace l'ensemble des scores de la session (voir PlayerEvaluationsService.update).
model PlayerEvaluationScore {
  id           Int                 @id @default(autoincrement())
  evaluationId Int
  evaluation   PlayerEvaluation    @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  criterionId  Int
  criterion    EvaluationCriterion @relation(fields: [criterionId], references: [id])
  score        Decimal             @db.Decimal(4, 1)

  @@unique([evaluationId, criterionId])
  @@index([evaluationId])
}

// ─────────────────────────────────────────────────────────────────────────
// Scouting (partiel) — docs/schema/scouting.md
// Uniquement les tables de référence pour le seed système Phase 1.
// Le reste du module (TeamScoutingReport, PlayerScoutingReport, etc.) arrive en Phase 7.
// ─────────────────────────────────────────────────────────────────────────

model PlayingStyleTag {
  id        Int      @id @default(autoincrement())
  name      String
  isSystem  Boolean
  clubId    Int?
  club      Club?    @relation(fields: [clubId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clubId])
}

enum ScoutingDimension {
  PHYSIQUE
  TECHNIQUE
  TACTIQUE
  MENTAL
}

model PlayerScoutingCriterion {
  id          Int               @id @default(autoincrement())
  name        String
  dimension   ScoutingDimension
  isSystem    Boolean
  clubId      Int?
  club        Club?             @relation(fields: [clubId], references: [id])
  description String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([clubId])
}
