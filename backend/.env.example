# Base de données
DATABASE_URL="postgresql://footmanager:footmanager_dev_password@localhost:5432/footmanager?schema=public"

# Serveur
PORT=3001
FRONTEND_URL="http://localhost:3000"

# JWT — access token (courte durée, jamais persisté)
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_ACCESS_EXPIRES_IN="15m"

# JWT — refresh token (cookie httpOnly, persisté hashé en base)
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_REFRESH_EXPIRES_IN="30d"
REFRESH_COOKIE_NAME="refresh_token"
